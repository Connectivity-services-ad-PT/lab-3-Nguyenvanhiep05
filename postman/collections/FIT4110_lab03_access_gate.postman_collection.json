{
  "info": {
    "name": "FIT4110 Lab03 — Access Gate",
    "_postman_id": "access-gate-lab03-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "TC01 — Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has status=ok', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json.service).to.eql('access-gate');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC02 — Create access event (happy path — allowed)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_id\": \"CARD-2026-001\",\n  \"gate_id\": \"GATE-01\",\n  \"direction\": \"in\",\n  \"timestamp\": \"2026-05-19T08:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access-events",
              "host": ["{{baseUrl}}"],
              "path": ["access-events"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has event_id', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('event_id');",
                  "});",
                  "",
                  "pm.test('Response has correct direction', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.direction).to.be.oneOf(['in', 'out']);",
                  "});",
                  "",
                  "pm.test('Response has result field', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.be.oneOf(['accepted', 'denied', 'error']);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC03 — Get access events list",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/access-events?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["access-events"],
              "query": [
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has items array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Response has total count', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('total');",
                  "  pm.expect(json.total).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC04 — Get card by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cards/CARD-2026-001",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "CARD-2026-001"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has card_id and holder_name', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('card_id');",
                  "  pm.expect(json).to.have.property('holder_name');",
                  "  pm.expect(json.status).to.be.oneOf(['active', 'expired', 'revoked']);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "TC05 — Missing token returns 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_id\": \"CARD-2026-001\",\n  \"gate_id\": \"GATE-01\",\n  \"direction\": \"in\",\n  \"timestamp\": \"2026-05-19T08:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access-events",
              "host": ["{{baseUrl}}"],
              "path": ["access-events"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Missing token returns 401 or 403', function () {",
                  "  pm.expect([401, 403]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Error follows ProblemDetails', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json.status).to.be.within(400, 599);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC06 — Invalid token returns 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid-token-xyz" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_id\": \"CARD-2026-001\",\n  \"gate_id\": \"GATE-01\",\n  \"direction\": \"in\",\n  \"timestamp\": \"2026-05-19T08:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access-events",
              "host": ["{{baseUrl}}"],
              "path": ["access-events"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Note: Prism mock does not validate auth tokens — this test is for local service",
                  "if (pm.environment.get('env') === 'local') {",
                  "  pm.test('Invalid token returns 401 or 403 (local)', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "} else {",
                  "  pm.test('Mock does not validate token — expected 201 on mock', function () {",
                  "    pm.expect([201, 401, 403]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03_Negative",
      "item": [
        {
          "name": "TC07 — Missing card_id returns 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gate_id\": \"GATE-01\",\n  \"direction\": \"in\",\n  \"timestamp\": \"2026-05-19T08:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access-events",
              "host": ["{{baseUrl}}"],
              "path": ["access-events"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Missing card_id returns client error', function () {",
                  "  pm.expect([400, 422]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Error follows ProblemDetails', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json.status).to.be.within(400, 599);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC08 — Invalid direction returns 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_id\": \"CARD-2026-001\",\n  \"gate_id\": \"GATE-01\",\n  \"direction\": \"up\",\n  \"timestamp\": \"2026-05-19T08:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access-events",
              "host": ["{{baseUrl}}"],
              "path": ["access-events"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid direction returns client error', function () {",
                  "  pm.expect([400, 422]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC09 — Card not found returns 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cards/CARD-NOT-EXIST-999",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "CARD-NOT-EXIST-999"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Note: Prism mock returns example for any path param — 404 only on local service",
                  "if (pm.environment.get('env') === 'local') {",
                  "  pm.test('Non-existent card returns 404 (local)', function () {",
                  "    pm.response.to.have.status(404);",
                  "  });",
                  "  pm.test('Error follows ProblemDetails (local)', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('title');",
                  "    pm.expect(json.status).to.eql(404);",
                  "  });",
                  "} else {",
                  "  pm.test('Mock returns 200 for any card path param — expected on mock', function () {",
                  "    pm.expect([200, 404]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "TC10 — Empty card_id boundary",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_id\": \"\",\n  \"gate_id\": \"GATE-01\",\n  \"direction\": \"in\",\n  \"timestamp\": \"2026-05-19T08:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access-events",
              "host": ["{{baseUrl}}"],
              "path": ["access-events"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Empty card_id is rejected or handled', function () {",
                  "  pm.expect([400, 422, 201]).to.include(pm.response.code);",
                  "",
                  "  if ([400, 422].includes(pm.response.code)) {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('detail');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC11 — Pagination limit boundary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/access-events?limit=200",
              "host": ["{{baseUrl}}"],
              "path": ["access-events"],
              "query": [
                { "key": "limit", "value": "200" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Limit exceeding max is handled', function () {",
                  "  pm.expect([200, 400, 422]).to.include(pm.response.code);",
                  "",
                  "  if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.items.length).to.be.at.most(100);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "TC12 — Smoke test Core Business mock (check policy)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_id\": \"CARD-2026-001\",\n  \"gate_id\": \"GATE-01\",\n  \"direction\": \"in\",\n  \"zone_id\": \"ZONE-A\"\n}"
            },
            "url": {
              "raw": "{{coreMockUrl}}/policies/evaluate-access",
              "host": ["{{coreMockUrl}}"],
              "path": ["policies", "evaluate-access"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Consumer-side smoke test: Access Gate calls Core Business mock",
                  "// Core Business mock must be running on port 4011",
                  "if (pm.response.code === undefined || pm.response.code === 0) {",
                  "  pm.test('Core Business mock not running — skip (start with npm run mock:core)', function () {",
                  "    pm.expect(true).to.be.true;",
                  "  });",
                  "} else {",
                  "  pm.test('Core Business mock responds', function () {",
                  "    pm.expect([200, 201]).to.include(pm.response.code);",
                  "  });",
                  "  pm.test('Response has allow/deny decision', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.any.keys('allowed', 'decision', 'result', 'action');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "06_Local_only_NonFunctional",
      "item": [
        {
          "name": "TC13 — Response time under 1000ms",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get('env') === 'local') {",
                  "  pm.test('Response time is below 1000ms on local service', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "  });",
                  "} else {",
                  "  pm.test('Skip latency test on mock (not meaningful)', function () {",
                  "    pm.expect(true).to.be.true;",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
