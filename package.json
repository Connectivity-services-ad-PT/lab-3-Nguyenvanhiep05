{
  "name": "fit4110_lab03_postman_mock_testing",
  "version": "0.3.0",
  "private": true,
  "description": "FIT4110 Lab 03 - Postman, Mock Server, Contract Testing, Newman CI — team-gate (Access Gate)",
  "scripts": {
    "mock:gate": "prism mock contracts/access-gate.openapi.yaml -p 4010 --host 0.0.0.0",
    "mock:core": "prism mock contracts/core-business.openapi.yaml -p 4011 --host 0.0.0.0",
    "wait:mock": "wait-on http://localhost:4010/health http://localhost:4011/health --timeout 60000",
    "test:mock": "newman run postman/collections/FIT4110_lab03_access_gate.postman_collection.json -e postman/environments/FIT4110_lab03_mock.postman_environment.json -r cli,junit --reporter-junit-export reports/newman-report-mock.xml",
    "test:local": "newman run postman/collections/FIT4110_lab03_access_gate.postman_collection.json -e postman/environments/FIT4110_lab03_local.postman_environment.json -r cli,junit --reporter-junit-export reports/newman-report-local.xml",
    "test:html": "newman run postman/collections/FIT4110_lab03_access_gate.postman_collection.json -e postman/environments/FIT4110_lab03_mock.postman_environment.json -r cli,htmlextra --reporter-htmlextra-export reports/newman-report.html",
    "lint": "npx @stoplight/spectral-cli lint contracts/access-gate.openapi.yaml"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.14.2",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1",
    "wait-on": "^8.0.1"
  }
}
